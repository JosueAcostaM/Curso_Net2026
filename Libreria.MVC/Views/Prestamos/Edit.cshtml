@model Libreria.Modelos.Prestamo

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Prestamo</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-group">
                <label asp-for="Descripcion_Prestamo" class="control-label"></label>
                <input asp-for="Descripcion_Prestamo" class="form-control" />
                <span asp-validation-for="Descripcion_Prestamo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Fecha_Prestamo" class="control-label"></label>
                <input asp-for="Fecha_Prestamo" class="form-control" />
                <span asp-validation-for="Fecha_Prestamo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Fecha_Devolucion" class="control-label"></label>
                <input asp-for="Fecha_Devolucion" class="form-control" />
                <span asp-validation-for="Fecha_Devolucion" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Estado_Prestamo" /> @Html.DisplayNameFor(model => model.Estado_Prestamo)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="ClienteId" class="control-label"></label>
                <select asp-for="ClienteId" class="form-control" asp-items="ViewBag.Clientes">
                    <option value="">-- Seleccion Clientes --</option>
                </select>                
                <span asp-validation-for="ClienteId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="LibroId" class="control-label"></label>
                <select asp-for="LibroId" class="form-control" asp-items="ViewBag.Libros">
                    <option value="">-- Seleccion Libros --</option>
                </select>
                <span asp-validation-for="LibroId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
